# Copy to .env and fill in your values. Used by deploy_cloudrun.sh.

# GCP project to deploy to (falls back to GOOGLE_CLOUD_PROJECT, then VITE_FIREBASE_PROJECT_ID in ui/.env)
GCP_PROJECT_ID=your-gcp-project-id

# Cloud Run region (default: us-central1)
GCP_REGION=us-central1

# Cloud Run service name (default: gcp-training)
CLOUD_RUN_SERVICE=gcp-training

# Optional: pre-deployed Agent Engine resource name, used by agent.py
# AGENT_ENGINE_NAME=projects/YOUR_PROJECT_NUMBER/locations/us-central1/reasoningEngines/YOUR_REASONING_ENGINE_ID
